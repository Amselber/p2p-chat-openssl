# =============================================================================
# Makefile для проекта P2P чата (на C)
# =============================================================================
# Этот файл описывает правила сборки:
#   - основной программы (src/*.c, исключая main.c для тестов)
#   - модульных тестов (tests/*.c + unity + исходники без main.c)
#   - генерацию файлов зависимостей (.d) для автоматического отслеживания
#     изменений в заголовочных файлах.
# =============================================================================

# -----------------------------------------------------------------------------
# Компилятор и флаги
# -----------------------------------------------------------------------------
# CC     : имя компилятора C
# CFLAGS : флаги компиляции:
#   -Wall -Wextra : все предупреждения и дополнительные
#   -std=c11      : стандарт C11
#   -g            : отладочная информация (для gdb)
# LDFLAGS : флаги линковщика (пока пусто, можно добавить -lm, -lpthread и т.п.)
CC = gcc
CFLAGS = -Wall -Wextra -Wpedantic -Wformat=2 -Wsign-conversion \
				 -Wcast-align -std=c11 -g
LDFLAGS = -lssl -lcrypto -lsqlite3
COVFLAGS = -fprofile-arcs -ftest-coverage
COVLDFLAGS = -lgcov --coverage

# -----------------------------------------------------------------------------
# Пути к фреймворку Unity (для модульного тестирования)
# -----------------------------------------------------------------------------
# UNITY_DIR   : директория с исходниками Unity
# UNITY_SRC   : полный путь к unity.c
# UNITY_HEADER: полный путь к unity.h (нужен для зависимостей)
UNITY_DIR = external/Unity/src
UNITY_SRC = $(UNITY_DIR)/unity.c
UNITY_HEADER = $(UNITY_DIR)/unity.h

# -----------------------------------------------------------------------------
# Директории проекта
# -----------------------------------------------------------------------------
# SRC_DIR   : исходный код приложения
# TEST_DIR  : тесты
# BUILD_DIR : объектные файлы (.o) и файлы зависимостей (.d)
# BIN_DIR   : готовые исполняемые файлы
# INC_DIR   : дополнительные заголовочные файлы (если есть)
SRC_DIR = src
TEST_DIR = tests
BUILD_DIR = build
BIN_DIR = bin
INC_DIR = include

# -----------------------------------------------------------------------------
# Автоматический поиск всех .c и .h файлов
# -----------------------------------------------------------------------------
# wildcard  : функция make, возвращает список файлов по шаблону
# SRC_FILES     : все .c из src/
# TEST_FILES    : все .c из tests/
# HEADER_FILES  : все .h из src/ и include/
# TEST_HEADERS  : все .h из tests/
SRC_FILES = $(wildcard $(SRC_DIR)/*.c)
TEST_FILES = $(wildcard $(TEST_DIR)/*.c)
HEADER_FILES = $(wildcard $(SRC_DIR)/*.h) $(wildcard $(INC_DIR)/*.h)
TEST_HEADERS = $(wildcard $(TEST_DIR)/*.h)

# -----------------------------------------------------------------------------
# Исключаем main.c из тестовой сборки
# -----------------------------------------------------------------------------
# filter-out : убирает из списка $(SRC_FILES) файл src/main.c
# В тестах не должно быть двух функций main() — своей у тестового runner'а
# и из основной программы.
SRC_FILES_WITHOUT_MAIN = $(filter-out $(SRC_DIR)/main.c, $(SRC_FILES))

# -----------------------------------------------------------------------------
# Преобразование списков .c в списки .o (объектные файлы)
# -----------------------------------------------------------------------------
# patsubst : заменяет часть имени по шаблону
#   $(SRC_DIR)/%.c -> $(BUILD_DIR)/%.o
# MAIN_OBJ     : объекты всех .c из src (включая main.c)
# TEST_OBJ     : объекты всех .c из tests
# SRC_OBJ_FOR_TESTS : объекты всех .c из src, кроме main.c (линкуются в тесты)
# UNITY_OBJ    : объектный файл самого Unity
MAIN_OBJ = $(patsubst $(SRC_DIR)/%.c, $(BUILD_DIR)/%.o, $(SRC_FILES))
TEST_OBJ = $(patsubst $(TEST_DIR)/%.c, $(BUILD_DIR)/%.o, $(TEST_FILES))
SRC_OBJ_FOR_TESTS = $(patsubst $(SRC_DIR)/%.c, $(BUILD_DIR)/%.o, $(SRC_FILES_WITHOUT_MAIN))
UNITY_OBJ = $(BUILD_DIR)/unity.o

# -----------------------------------------------------------------------------
# Файлы зависимостей (.d)
# -----------------------------------------------------------------------------
# При компиляции с флагом -MMD компилятор генерирует .d файлы, в которых
# перечислены все заголовки, от которых зависит данный .c файл.
# Это позволяет make пересобирать .o когда меняется любой включённый .h.
# DEPS : список всех возможных .d файлов (для основных .o, тестовых .o, unity.o)
DEPS = $(MAIN_OBJ:.o=.d) $(TEST_OBJ:.o=.d) $(SRC_OBJ_FOR_TESTS:.o=.d) $(UNITY_OBJ:.o=.d)

# -----------------------------------------------------------------------------
# Имена итоговых исполняемых файлов
# -----------------------------------------------------------------------------
MAIN_BIN = $(BIN_DIR)/p2pchat   # основная программа
TEST_BIN = $(BIN_DIR)/test_runner   # бегунок тестов

# -----------------------------------------------------------------------------
# Пути для поиска заголовочных файлов (флаги -I)
# -----------------------------------------------------------------------------
# Добавляем все директории, где могут лежать .h:
#   - src (основные заголовки модулей)
#   - include (публичные заголовки)
#   - external/Unity/src (заголовки фреймворка unity)
#   - tests (заголовки тестов, если есть)
INCLUDES = -I$(SRC_DIR) -I$(INC_DIR) -I$(UNITY_DIR) -I$(TEST_DIR)

# =============================================================================
# Цели (targets) и правила
# =============================================================================

# .PHONY : цели, которые не соответствуют реальным файлам.
#          Всегда выполняются, даже если существует файл с таким именем.
.PHONY: all clean test run info

# -----------------------------------------------------------------------------
# all (по умолчанию) — сборка только основной программы
# -----------------------------------------------------------------------------
all: $(MAIN_BIN)

# -----------------------------------------------------------------------------
# Правило сборки основной программы
# -----------------------------------------------------------------------------
# $^   : все зависимости (справа от двоеточия) — в данном случае $(MAIN_OBJ)
# $@   : имя цели (слева от двоеточия) — $(MAIN_BIN)
# mkdir -p : создаёт bin/, если её нет
$(MAIN_BIN): $(MAIN_OBJ)
	@mkdir -p $(BIN_DIR)
	$(CC) $^ -o $@ $(LDFLAGS)

# -----------------------------------------------------------------------------
# Правило компиляции любого .c из src/ в .o (с генерацией .d)
# -----------------------------------------------------------------------------
# %   : шаблон, подставляющий имя файла
# -MMD: генерировать файл зависимостей (.d) в том же формате, что make понимает
# -MP : добавить фиктивные цели для каждого заголовка (защита от удаления .h)
# -c  : только компиляция, без линковки
# $<  : первая зависимость (исходный .c файл)
$(BUILD_DIR)/%.o: $(SRC_DIR)/%.c
	@mkdir -p $(BUILD_DIR)
	$(CC) $(CFLAGS) $(INCLUDES) -MMD -MP -c $< -o $@

# -----------------------------------------------------------------------------
# Цель test: собрать и запустить тесты
# -----------------------------------------------------------------------------
test: $(TEST_BIN)
	./certs/gen_certs.sh bin/tmp client
	./$(TEST_BIN)

# -----------------------------------------------------------------------------
# Правило сборки тестового бегунка
# -----------------------------------------------------------------------------
# Зависит от:
#   - объектных файлов тестов (*.o из tests/)
#   - объектных файлов исходников без main.c
#   - объектного файла unity
$(TEST_BIN): $(TEST_OBJ) $(SRC_OBJ_FOR_TESTS) $(UNITY_OBJ)
	@mkdir -p $(BIN_DIR)
	$(CC) $^ -o $@ $(LDFLAGS)

# -----------------------------------------------------------------------------
# Правило компиляции любого .c из tests/ в .o (с генерацией .d)
# -----------------------------------------------------------------------------
$(BUILD_DIR)/%.o: $(TEST_DIR)/%.c
	@mkdir -p $(BUILD_DIR)
	$(CC) $(CFLAGS) $(INCLUDES) -MMD -MP -c $< -o $@

# -----------------------------------------------------------------------------
# Правило компиляции unity.c в unity.o (с генерацией .d)
# -----------------------------------------------------------------------------
$(UNITY_OBJ): $(UNITY_SRC) $(UNITY_HEADER)
	@mkdir -p $(BUILD_DIR)
	$(CC) $(CFLAGS) $(INCLUDES) -MMD -MP -c $< -o $@

# -----------------------------------------------------------------------------
# Запуск основной программы (удобно для make run)
# -----------------------------------------------------------------------------
run: $(MAIN_BIN)
	./$(MAIN_BIN)

# Сборка с покрытием
coverage: CFLAGS += $(COVFLAGS)
coverage: LDFLAGS += $(COVLDFLAGS)
coverage: clean $(TARGET)

# -----------------------------------------------------------------------------
# Очистка: удаляем все сгенерированные файлы
# -----------------------------------------------------------------------------
clean:
	rm -rf $(BUILD_DIR) $(BIN_DIR)
	# rm -f src/*.o $(TARGET)
	# rm -f src/*.gcda src/*.gcno src/*.gcov
	# rm -rf coverage_report coverage.info

itest:
	@echo "Dependencies: Zellij terminal multiplexer"
	make clean
	make
	./tests/integration/init.sh
	./tests/integration/run.sh
# -----------------------------------------------------------------------------
# Информация о проекте (диагностика make-файла)
# -----------------------------------------------------------------------------
info:
	@echo "=== Project Structure ==="
	@echo "Source files: $(SRC_FILES)"
	@echo "Test files: $(TEST_FILES)"
	@echo "Header files: $(HEADER_FILES)"
	@echo "Main objects: $(MAIN_OBJ)"
	@echo "Test objects: $(TEST_OBJ)"
	@echo "=== Commands ==="
	@echo "  make        - build application"
	@echo "  make test   - build and run tests"
	@echo "  make run    - run application"
	@echo "  make clean  - remove build artifacts"
	@echo "=== Build Info ==="
	@echo "Include paths: $(INCLUDES)"

# -----------------------------------------------------------------------------
# Включение сгенерированных файлов зависимостей (если они есть)
# -----------------------------------------------------------------------------
# -include : игнорировать ошибку, если файл не найден (на первой сборке .d ещё нет)
# Благодаря этому make подхватывает автоматически вычисленные зависимости,
# и при изменении любого .h пересобираются только нужные .o файлы.
-include $(DEPS)
